{
  "name": "ecom",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",

    "dev:client": "turbo run dev --filter=client --filter=*-service",
    "dev:admin": "turbo run dev --filter=admin --filter=*-service",
    "dev:backend": "turbo run dev --filter=*-service",

    "dev:product-service": "turbo run dev --filter=product-service",
    "dev:payment-service": "turbo run dev --filter=payment-service",
    "dev:order-service": "turbo run dev --filter=order-service",

    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.7",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
